# ============================================================
# NPD Plan 스킬 — 사전 설정 항목
# 사용자가 워크플로우 실행 전에 결정해야 하는 항목입니다.
# 값을 미리 채워두면 실행 중 질문을 줄일 수 있습니다.
# ============================================================

# --- Step 0: 진행 모드 ---
# 각 단계 완료 후 승인을 받고 진행할지, 자동으로 진행할지 선택
# 값: 단계별승인 | 자동진행
PLAN_PROGRESS_MODE=

# --- Step 5: 고객 경험 조사 규모 ---
# 고객경험 인터뷰 대상자 수 (기본값: 10)
PLAN_INTERVIEW_COUNT=10
# 관찰 조사 횟수 (기본값: 10)
PLAN_OBSERVATION_COUNT=10
# 체험 테스트 횟수 (기본값: 10)
PLAN_EXPERIENCE_COUNT=10

# --- Step 7-2: 문제 검증 인터뷰 규모 ---
# 문제검증 인터뷰 대상자 수 (기본값: 10)
PLAN_PROBLEM_INTERVIEW_COUNT=10

# --- Step 15: 디자인 레퍼런스 ---
# 참고할 디자인 레퍼런스 URL 또는 이미지 경로
# 추천: https://wwit.design
# 없으면 비워둠
PLAN_DESIGN_REFERENCE=

# --- Step 16: 이미지 생성용 Gemini API Key ---
# 프로토타입에 AI 이미지 생성이 필요한 경우 사용
# 발급: https://aistudio.google.com/apikey
# 없으면 placeholder 텍스트로 대체됨
PLAN_GEMINI_API_KEY=
