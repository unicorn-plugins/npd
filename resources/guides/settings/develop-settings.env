# ============================================================
# NPD Develop 스킬 — 사전 설정 항목
# 사용자가 워크플로우 실행 전에 결정해야 하는 항목입니다.
# 값을 미리 채워두면 실행 중 질문을 줄일 수 있습니다.
# ============================================================

# --- Step 0-1: 개발 범위 ---
# 구현할 개발 단계 (Phase 번호, 쉼표 구분)
# HighLevel 아키텍처 정의서(14.1 개발 단계) 테이블에서 선택
# 예) 1,2
DEVELOP_PHASES=

# --- Step 0-2-1: OAuth2 크리덴셜 (조건부) ---
# 설계서에 OAuth2/소셜 로그인이 정의된 경우에만 필요
# 불필요 시 비워둠
# Provider별 앱 등록 가이드: resources/references/oauth2-provider-setup-guide.md
#
# Google
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
# 카카오
OAUTH2_KAKAO_CLIENT_ID=
OAUTH2_KAKAO_CLIENT_SECRET=
# 네이버
OAUTH2_NAVER_CLIENT_ID=
OAUTH2_NAVER_CLIENT_SECRET=

# --- Step 0-2-2: Gemini API Key ---
# 프론트엔드 이미지(아이콘, 일러스트, 배너) 생성용
# 발급: https://aistudio.google.com/apikey
# 없으면 CSS/SVG 기반 대체 구현
GEMINI_API_KEY=

# --- Step 0-2-3: AI 서비스 크리덴셜 (조건부) ---
# 설계서(ai-service-design.md)에 AI 서비스 연동이 정의된 경우에만 필요
# 불필요 시 비워둠
#
# LLM Provider API Key (사용하는 것만 입력)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 웹검색 Tool (Tavily 사용 시)
TAVILY_API_KEY=
# LLM 모니터링 (LangSmith 사용 시)
LANGSMITH_API_KEY=

# --- Step 0-2-4: 테스트 모드 ---
# 브라우저 테스트(Step 5~7) 진행 방식
# 자동진행 모드에서는 강제로 "자동"으로 설정됨
# 값: 자동 | 수동
DEVELOP_TEST_MODE=

# --- Step 0-3: 진행 모드 ---
# 각 단계 완료 후 승인을 받고 진행할지, 자동으로 진행할지 선택
# 값: 단계별승인 | 자동진행
DEVELOP_PROGRESS_MODE=
