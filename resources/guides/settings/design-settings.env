# ============================================================
# NPD Design 스킬 — 사전 설정 항목
# 사용자가 워크플로우 실행 전에 결정해야 하는 항목입니다.
# 값을 미리 채워두면 실행 중 질문을 줄일 수 있습니다.
# ============================================================

# --- Step 0-1-1: 패키지 네이밍 ---
# Java 패키지명에 사용할 회사/조직명
# 예) unicorn → com.unicorn.{ROOT}.{서비스명}
DESIGN_ORG=
# 대표 시스템명 (Root Project명)
# 예) lifesub → com.{ORG}.lifesub.{서비스명}
DESIGN_ROOT=

# --- Step 0-1-2: Cloud 서비스 ---
# 사용할 Cloud 서비스 선택
# 값: AWS | Azure | GCP
DESIGN_CLOUD=

# --- Step 0-2: 진행 모드 ---
# 각 단계 완료 후 승인을 받고 진행할지, 자동으로 진행할지 선택
# 값: 단계별승인 | 자동진행
DESIGN_PROGRESS_MODE=

# --- Step 1-R: 아키텍처 패턴 리뷰 (단계별승인 모드에서만) ---
# 아키텍처 패턴 선정 결과에 대해 리뷰를 수행할지 선택
# 자동진행 모드에서는 리뷰를 건너뜀
# 값: 리뷰수행 | 건너뛰기
DESIGN_PATTERN_REVIEW=

# --- Step 5-0b: 마이크로서비스별 설계 아키텍처 패턴 (단계별승인 모드에서만) ---
# 자동진행 모드에서는 architect가 서비스 특성을 분석하여 자율 결정
# 단계별승인 모드에서는 서비스별로 사용자가 선택
# 값: Layered | Clean
# 형식: DESIGN_PATTERN_{서비스영문명(대문자)}=패턴
# 예)
# DESIGN_PATTERN_USER_SERVICE=Layered
# DESIGN_PATTERN_ORDER_SERVICE=Clean
# DESIGN_PATTERN_PAYMENT_SERVICE=Layered
# (서비스 목록은 logical-architecture.md에서 확인, AI 서비스는 제외)
